{
    "mcpServers": {
        "context7": {
            "command": "npx",
            "args": [
                "-y",
                "@upstash/context7-mcp",
                "--api-key",
                "YOUR_API_KEY"
            ]
        },
        "shadcn": {
            "command": "npx",
            "args": [
                "shadcn@latest",
                "mcp"
            ]
        },
        "drizzle-docs": {
            "command": "npx",
            "args": [
                "-y",
                "mcp-remote",
                "https://drizzle.mastra.cloud/api/mcp/drizzle-docs-mcp/mcp"
            ]
        }
    }
}
